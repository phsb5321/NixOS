keys:
  # Personal admin key (for editing secrets locally)
  - &admin_key YOUR_PERSONAL_PUBLIC_KEY_HERE

  # Laptop host key (from ssh-to-age output)
  - &host_laptop YOUR_LAPTOP_HOST_PUBLIC_KEY_HERE

creation_rules:
  # Laptop host secrets
  - path_regex: laptop\.yaml$
    key_groups:
      - age:
          - *admin_key
          - *host_laptop
